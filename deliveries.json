message || err));\\n            del\x5b\x27Час\x27\x5d \x3d oldTime;\\n            del\x5b\x27ID_Авто\x27\x5d \x3d oldCar;\\n            del\x5b\x27Дата\x27\x5d \x3d oldDate;\\n            renderCalendar();\\n          \x7d)\\n          .updateDeliveryDetails(delId, deliveryData, user.role);\\n    \x7d\\n  \x3cdiv id\x3d\\\x22advanced-filters-modal\\\x22 class\x3d\\\x22modal-overlay\\\x22\x3e\\n    \x3cdiv class\x3d\\\x22modal-content\\\x22 style\x3d\\\x22max-width: 400px;\\\x22\x3e\\n      \x3cdiv class\x3d\\\x22modal-header\\\x22\x3e\\n        \x3ch3 id\x3d\\\x22filters-modal-title\\\x22\x3eФільтри\x3c\\\/h3\x3e\\n        \x3cbutton class\x3d\\\x22close-btn\\\x22 onclick\x3d\\\x22closeModal(\x27advanced-filters-modal\x27)\\\x22\x3e×\x3c\\\/button\x3e\\n      \x3c\\\/div\x3e\\n      \x3cdiv class\x3d\\\x22modal-body\\\x22 style\x3d\\\x22padding: 20px;\\\x22\x3e\\n        \x3cdiv style\x3d\\\x22margin-bottom: 15px;\\\x22\x3e\\n          \x3clabel style\x3d\\\x22font-weight: bold; margin-bottom: 5px; display: block;\\\x22\x3eАвтомобіль:\x3c\\\/label\x3e\\n          \x3cdiv style\x3d\\\x22display: flex; flex-direction: column; gap: 5px;\\\x22\x3e\\n            \x3clabel\x3e\x3cinput type\x3d\\\x22checkbox\\\x22 class\x3d\\\x22filter-car-cb\\\x22 value\x3d\\\x221\\\x22\x3e Авто 1\x3c\\\/label\x3e\\n            \x3clabel\x3e\x3cinput type\x3d\\\x22checkbox\\\x22 class\x3d\\\x22filter-car-cb\\\x22 value\x3d\\\x222\\\x22\x3e Авто 2\x3c\\\/label\x3e\\n            \x3clabel\x3e\x3cinput type\x3d\\\x22checkbox\\\x22 class\x3d\\\x22filter-car-cb\\\x22 value\x3d\\\x223\\\x22\x3e Авто 3\x3c\\\/label\x3e\\n            \x3clabel\x3e\x3cinput type\x3d\\\x22checkbox\\\x22 class\x3d\\\x22filter-car-cb\\\x22 value\x3d\\\x224\\\x22\x3e Авто 4\x3c\\\/label\x3e\\n            \x3clabel\x3e\x3cinput type\x3d\\\x22checkbox\\\x22 class\x3d\\\x22filter-car-cb\\\x22 value\x3d\\\x22Не призначено\\\x22\x3e Не призначено\x3c\\\/label\x3e\\n          \x3c\\\/div\x3e\\n        \x3c\\\/div\x3e\\n  