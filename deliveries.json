ndler(function(err) \x7b\\n              try \x7b\\n                submitBtn.disabled \x3d false;\\n                submitBtn.textContent \x3d \\\x22Увійти в систему\\\x22;\\n                const errMsg \x3d err.message || err;\\n                errorMsg.textContent \x3d \\\x22Помилка сервера: \\\x22 + errMsg;\\n                errorMsg.style.display \x3d \x27block\x27;\\n              \x7d catch (innerErr) \x7b\\n                errorMsg.textContent \x3d \\\x22UI Crash (Failure): \\\x22 + innerErr.message;\\n                errorMsg.style.display \x3d \x27block\x27;\\n              \x7d\\n            \x7d)\\n            .authenticateUser(username, password);\\n        \x7d else \x7b\\n          errorMsg.textContent \x3d \\\x22API is undefined. Bridge initialization failed.\\\x22;\\n          errorMsg.style.display \x3d \x27block\x27;\\n          submitBtn.disabled \x3d false;\\n          submitBtn.textContent \x3d \\\x22Увійти в систему\\\x22;\\n        \x7d\\n      \x7d catch (err) \x7b\\n        console.error(\\\x22Помилка в handleLogin:\\\x22, err);\\n        const errorMsg \x3d document.getElementById(\x27login-error-msg\x27);\\n        if (errorMsg) \x7b\\n          errorMsg.textContent \x3d \\\x22Критична помилка в handleLogin: \\\x22 + err.message;\\n          errorMsg.style.display \x3d \x27block\x27;\\n        \x7d\\n      \x7d\\n    \x7d\\n    function loginUser(user) \x7b\\n      state.currentUser \x3d user;\\n      try \x7b sessionStorage.setItem(\x27propex_user\x27, JSON.stringify(user)); \x7d catch(e) \x7b console.warn(\x27Storage blocked\x27); \x7d\\n      document.getElementById(\x27user-profile-name\x27).textContent \x3d user.name;\\n      document.getElementById(\x27user-profile-role\x27).textContent \x3d user.role.toUpperCase();\\n      document.getElementById(\x27user-avatar-char\x27).textContent \x3d user.name.charAt(0).toUpperCase();\\n      document.getElementById(\x27login-container\x27).style.display \x3d \x27none\x27;\\n      document.getElementById(\x27app-wrapper\x27).style.display \x3d \x27block\x27;\\n      document.getElementById(\x27user-profile-widget\x27).style.display \x3d \x27flex\x27;\\n      applyRoleRestrictions();\\n      loadData();\\n      document.getElementById(\x27login-username\x27).value \x3d \x27\x27;\\n      document.getElementById(\x27login-password\x27).value \x3d \x27\x27;\\n    \x7d\\n    function handleLogout() \x7b\\n      state.currentUser \x3d null;\\n      try \x7b sessionStorage.removeItem(\x27propex_user\x27); \x7d catch(e) \x7b\x7d\\n      document.getElementById(\x27login-container\x27).style.display \x3d \x27flex\x27;\\n      document.getElementById(\x27app-wrapper\x27).style.display \x3d \x27none\x27;\\n      document.getElementById(\x27user-profile-widget\x27).style.display \x3d \x27none\x27;\\n      document.getElementById(\x27director-mode-banner\x27).style.display \x3d \x27none\x27;\\n    \x7d\\n    function checkSession() \x7b\\n      let savedUser \x3d null;\\n      try \x7b savedUser \x3d sessionStorage.getItem(\x27propex_user\x27); \x7d catch(e) \x7b\x7d\\n      if (savedUser) \x7b\\n        try \x7b\\n          const user \x3d JSON.parse(savedUser);\\n          loginUser(user);\\n        \x7d catch (e) \x7b\\n          handleLogout();\\n        \x7d\\n      \x7d else \x7b\\n        handleLogout();\\n      \x7d\\n    \x7d\\n    function applyRoleRestrictions() \x7b\\n      const user \x3d state.currentUser;\\n      if (!user) return;\\n      const banner \x3d document.getElementById(\x27director-mode-banner\x27);\\n      const addBtn \x3d document.getElementById(\x27add-delivery-btn\x27);\\n      if (user.role \x3d\x3d\x3d \x27director\x27) \x7b\\n        banner.style.display \x3d \x27block\x27;\\n        banner.className \x3d \x27director-banner\x27;\\n        banner.style.background \x3d \x27linear-gradient(90deg, rgba(217, 119, 6, 0.15) 0%, rgba(217, 119, 6, 0.05) 100%)\x27;\\n        banner.style.borderBottom \x3d \x271px solid rgba(217, 119, 6, 0.2