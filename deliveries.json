  div.textContent \x3d \\\x22⚠️ Помилка пошуку (можливо, ліміт запитів). Спробуйте ввести вручну.\\\x22;\\n            autocompleteList.appendChild(div);\\n          \x7d);\\n      \x7d, 400);\\n    \x7d);\\n    document.addEventListener(\x27click\x27, function (e) \x7b\\n      if (e.target !\x3d\x3d addressInput) autocompleteList.innerHTML \x3d \x27\x27;\\n    \x7d);\\n    function handleDragOver(e) \x7b\\n      e.preventDefault();\\n      const cell \x3d e.currentTarget.closest(\x27.grid-cell\x27);\\n      if (cell) cell.classList.add(\x27drag-hover\x27);\\n    \x7d\\n    function handleDragLeave(e) \x7b\\n      const cell \x3d e.currentTarget.closest(\x27.grid-cell\x27);\\n      if (cell) cell.classList.remove(\x27drag-hover\x27);\\n    \x7d\\n    function handleDrop(e) \x7b\\n      e.preventDefault();\\n      const cell \x3d e.currentTarget.closest(\x27.grid-cell\x27);\\n      if (!cell) return;\\n      cell.classList.remove(\x27drag-hover\x27);\\n      const delId \x3d e.dataTransfer.getData(\x27text\/plain\x27);\\n      if (!delId) return;\\n      const newTime \x3d cell.dataset.time;\\n      const newCarId \x3d cell.dataset.car;\\n      const newDate \x3d cell.dataset.date;\\n      moveDelivery(delId, newTime, newCarId, newDate);\\n    \x7d\\n    function moveDelivery(delId, newTime, newCarId, newDate) \x7b\\n      const user \x3d state.currentUser;\\n      if (!user) return;\\n      const del \x3d state.deliveries.find(d \x3d\x3e d\x5b\x27ID\x27\x5d \x3d\x3d delId);\\n      if (!del) return;\\n      if (user.role \x3d\x3d\x3d \x27manager\x27) \x7b\\n        if (del\x5b\x27ID_Менеджера\x27\x5d !\x3d user.telegramId) \x7b\\n          alert(\\\x22Ви не можете переносити замовлення інших менеджерів!\\\x22);\\n          return;\\n        \x7d\\n        if (newCarId \x26\x26 String(newCarId) !\x3d\x3d String(del\x5b\x27ID_Авто\x27\x5d)) \x7b\\n          alert(\\\x22Менеджери не мають прав на зміну призначеного автомобіля!\\\x22);\\n          return;\\n        \x7d